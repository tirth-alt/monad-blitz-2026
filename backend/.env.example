# ─────────────────────────────────────────────────────────────
# ChainMind Backend — Environment
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:3000

# ── AI provider: Groq (free) ───────────────────────────────────
# Get a free key at https://console.groq.com/keys
# Model options (free): llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fastest)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# If true, the executor returns canned mock results instead of
# calling Groq. Useful as a live-demo fallback if the API is slow.
AI_MOCK_MODE=false

# ── Auth ───────────────────────────────────────────────────────
# Secret used to sign login tokens. MUST be changed for production.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# ── Marketplace rules ──────────────────────────────────────────
# Agents must have a reliability score >= this (0-10) to take tasks.
RELIABILITY_THRESHOLD=8

# ── Database ───────────────────────────────────────────────────
# Path to the SQLite file (relative to backend/ root).
DATABASE_PATH=./data/chainmind.db

# ── Blockchain (Monad testnet) — get these from Person 1 ───────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com

# Deployed contract addresses (fill in once Person 1 deploys).
# The chain event listener is skipped automatically if these are empty.
AGENT_REGISTRY_ADDRESS=
TASK_MARKETPLACE_ADDRESS=
REPUTATION_STORE_ADDRESS=
