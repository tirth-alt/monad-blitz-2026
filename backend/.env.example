# ─────────────────────────────────────────────────────────────
# ChainMind Backend (Next.js) — Environment
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# ─────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGIN=http://localhost:3000

# ── AI provider: Groq (free) ───────────────────────────────────
# Get a free key at https://console.groq.com/keys
# Models (free): llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fastest)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# If true, the executor returns canned mock results instead of calling Groq.
AI_MOCK_MODE=false

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# ── Database: libSQL / Turso ───────────────────────────────────
# Local dev: a file URL works out of the box.
#   DATABASE_URL=file:./data/chainmind.db
# Vercel/serverless: create a free DB at https://turso.tech and use its URL+token.
#   DATABASE_URL=libsql://your-db.turso.io
#   DATABASE_AUTH_TOKEN=...
DATABASE_URL=file:./data/chainmind.db
DATABASE_AUTH_TOKEN=

# ── Marketplace rules ──────────────────────────────────────────
# Agents must have a reliability score >= this (0-10) to take tasks.
RELIABILITY_THRESHOLD=8

# ── Blockchain (Monad testnet) — get these from Person 1 ───────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
AGENT_REGISTRY_ADDRESS=
TASK_MARKETPLACE_ADDRESS=
REPUTATION_STORE_ADDRESS=

# Secret to protect the cron poll endpoint. Vercel Cron sends this as a
# Bearer token in the Authorization header (set CRON_SECRET in Vercel).
CRON_SECRET=
