# Deployer / backend wallet private key (NO 0x prefix issues — include the 0x).
# Use a throwaway wallet funded from the Monad faucet. NEVER commit the real .env.
PRIVATE_KEY=0xyour_private_key_here

# Optional override; defaults to the public Monad testnet RPC if unset.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
